# Python venvs — 모든 패턴 제외 (루트 + 하위 어디든, 점(.) 접두사 포함)
**/venv/
**/.venv/
**/*venv*/

# Python cache
python_engine/__pycache__/
python_engine/.pytest_cache/
**/__pycache__/
**/*.py[cod]

# Python secrets
python_engine/.env
python_engine/.env.local

# Dev-only scripts
check_db.js
python_engine/test_db.py
python_engine/test_*.py
python_engine/*.bak

# Vercel cache
.vercel/

# Node
node_modules/
dist/
dist-ssr/

# Temporary / backup directories (점 접두사로 숨겨진 변형까지 포함)
hello-fly/
**/*backup*/

# Editor / OS
.vscode/
.idea/
.DS_Store

# Logs
logs/
*.log

# Misc scratch files
diff.txt
test_conc.js
